---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const home = await getEntry("pages", "home");
const siteMetadata = await getEntry("site", "metadata");
const services = (await getCollection("services")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const projects = (await getCollection("projects")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

if (!home) {
	throw new Error("Missing src/content/pages/home.md");
}

const { Content } = await render(home);
const contactPhone = home.data.contact?.phone || home.data.phone;
const contactEmail = home.data.contact?.email || home.data.email;
const metadata = siteMetadata?.data ?? home.data.meta;
const meta = {
	title: metadata?.title ?? home.data.title ?? "Luc Contracting",
	description: metadata?.description ?? home.data.description,
	canonicalPath: metadata?.canonical_path ?? "/",
	socialTitle: metadata?.social_title,
	socialDescription: metadata?.social_description,
	socialImage: metadata?.social_image,
};
---

<Layout
	title={meta.title}
	description={meta.description}
	canonicalPath={meta.canonicalPath}
	socialTitle={meta.socialTitle}
	socialDescription={meta.socialDescription}
	socialImage={meta.socialImage}
>
	<header class="site-header">
		<a class="brand" href="/">Luc Contracting</a>
		<nav aria-label="Primary navigation">
			<a href="#services">Services</a>
			<a href="#work">Work</a>
			<a href="#contact">Contact</a>
		</nav>
	</header>

	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">General contracting</p>
				<h1>{home.data.hero_heading}</h1>
				<p class="lede">{home.data.hero_text}</p>
				<div class="actions">
					<a class="button" href={`tel:${home.data.phone.replace(/[^\d+]/g, "")}`}>
						{home.data.cta_label ?? "Request an estimate"}
					</a>
					<a class="text-link" href="#services">View services</a>
				</div>
			</div>
			<div class="hero-panel" aria-label="Project highlights">
				<span>Remodels</span>
				<span>Repairs</span>
				<span>Coordination</span>
			</div>
		</section>

		<section class="intro" aria-label="About Luc Contracting">
			<div>
				<h2>{home.data.intro_heading ?? "Clear work, steady communication, clean results."}</h2>
			</div>
			<div class="rich-text">
				<Content />
				{home.data.service_area && <p>{home.data.service_area}</p>}
			</div>
		</section>

		<section id="services" class="section">
			<div class="section-heading">
				<p class="eyebrow">{home.data.services_eyebrow ?? "Services"}</p>
				<h2>{home.data.services_heading ?? "Built for practical residential and small commercial projects."}</h2>
			</div>
			<div class="service-grid">
				{services.map((service) => (
					<article>
						<h3>{service.data.title}</h3>
						<p>{service.data.summary}</p>
					</article>
				))}
			</div>
		</section>

		<section id="work" class="section work">
			<div class="section-heading">
				<p class="eyebrow">{home.data.projects_eyebrow ?? "Recent work"}</p>
				<h2>{home.data.projects_heading ?? "Simple examples Decap can update as new projects finish."}</h2>
			</div>
			<div class="project-list">
				{projects.map((project) => (
					<article>
						<div>
							<h3>{project.data.title}</h3>
							{project.data.location && <p class="meta">{project.data.location}</p>}
						</div>
						<p>{project.data.summary}</p>
					</article>
				))}
			</div>
		</section>

		<section id="contact" class="contact">
			<div>
				<p class="eyebrow">{home.data.contact?.eyebrow ?? "Start a project"}</p>
				<h2>{home.data.contact?.heading ?? "Tell us what you need built, repaired, or managed."}</h2>
			</div>
			<div class="contact-actions">
				<a class="button" href={`tel:${contactPhone.replace(/[^\d+]/g, "")}`}>
					{contactPhone}
				</a>
				{contactEmail && <a class="text-link" href={`mailto:${contactEmail}`}>{contactEmail}</a>}
			</div>
		</section>
	</main>
</Layout>

<style>
	.site-header {
		align-items: center;
		display: flex;
		justify-content: space-between;
		margin: 0 auto;
		max-width: 1120px;
		padding: 24px;
	}

	.brand {
		font-size: 1rem;
		font-weight: 800;
		text-decoration: none;
	}

	nav {
		display: flex;
		gap: 20px;
	}

	nav a,
	.text-link {
		font-weight: 700;
		text-decoration: none;
	}

	main {
		overflow: hidden;
	}

	.hero,
	.intro,
	.section,
	.contact {
		margin: 0 auto;
		max-width: 1120px;
		padding: 56px 24px;
	}

	.hero {
		align-items: stretch;
		display: grid;
		gap: 28px;
		grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
		min-height: 620px;
	}

	.hero-copy {
		align-self: center;
	}

	.eyebrow {
		color: #8a4b2a;
		font-size: 0.78rem;
		font-weight: 800;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(3rem, 8vw, 6.4rem);
		line-height: 0.92;
		margin-bottom: 24px;
		max-width: 880px;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1;
		margin-bottom: 0;
	}

	h3 {
		font-size: 1.25rem;
		margin-bottom: 12px;
	}

	.lede,
	.rich-text,
	.service-grid p,
	.project-list p {
		color: #4a514b;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.lede {
		max-width: 640px;
	}

	.actions,
	.contact-actions {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
		margin-top: 34px;
	}

	.button {
		background: #1f2520;
		border-radius: 6px;
		color: #ffffff;
		display: inline-flex;
		font-weight: 800;
		justify-content: center;
		min-width: 180px;
		padding: 15px 22px;
		text-decoration: none;
	}

	.hero-panel {
		background:
			linear-gradient(rgba(31, 37, 32, 0.15), rgba(31, 37, 32, 0.56)),
			url("/uploads/hero-construction.jpg");
		background-position: center;
		background-size: cover;
		border-radius: 8px;
		display: grid;
		gap: 12px;
		min-height: 420px;
		padding: 24px;
	}

	.hero-panel span {
		align-self: end;
		background: rgba(255, 255, 255, 0.88);
		border-radius: 6px;
		font-weight: 800;
		padding: 14px 16px;
	}

	.intro {
		border-top: 1px solid #ded7cc;
		display: grid;
		gap: 48px;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
	}

	.section-heading {
		margin-bottom: 34px;
		max-width: 760px;
	}

	.service-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-grid article,
	.project-list article {
		background: #ffffff;
		border: 1px solid #e4ded4;
		border-radius: 8px;
		padding: 24px;
	}

	.work {
		background: #ece6db;
		max-width: none;
		padding-left: max(24px, calc((100vw - 1120px) / 2 + 24px));
		padding-right: max(24px, calc((100vw - 1120px) / 2 + 24px));
	}

	.project-list {
		display: grid;
		gap: 16px;
	}

	.project-list article {
		align-items: start;
		display: grid;
		gap: 24px;
		grid-template-columns: 0.45fr 1fr;
	}

	.meta {
		color: #8a4b2a;
		font-weight: 800;
		margin-bottom: 0;
	}

	.contact {
		align-items: center;
		display: grid;
		gap: 32px;
		grid-template-columns: minmax(0, 1fr) auto;
	}

	@media (max-width: 820px) {
		.site-header,
		nav,
		.actions,
		.contact-actions {
			align-items: flex-start;
			flex-direction: column;
		}

		.hero,
		.intro,
		.contact,
		.project-list article {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 28px;
		}

		.service-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

