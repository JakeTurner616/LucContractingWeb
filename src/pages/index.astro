---
import { getCollection, getEntry, render } from "astro:content";
import { readFileSync } from "node:fs";
import { extname } from "node:path";
import Layout from "../layouts/Layout.astro";

const home = await getEntry("pages", "home");
const siteMetadata = await getEntry("site", "metadata");
const services = (await getCollection("services")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const projects = (await getCollection("projects")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

if (!home) {
	throw new Error("Missing src/content/pages/home.md");
}

const { Content } = await render(home);
const contactPhone = home.data.contact?.phone || home.data.phone;
const contactEmail = home.data.contact?.email || home.data.email;
const metadata = siteMetadata?.data ?? home.data.meta;
const meta = {
	title: metadata?.title ?? home.data.title ?? "Luc Contracting",
	description: metadata?.description ?? home.data.description,
	canonicalPath: metadata?.canonical_path ?? "/",
	socialTitle: metadata?.social_title,
	socialDescription: metadata?.social_description,
	socialImage: metadata?.social_image,
};
const heroScopeText = home.data.hero_scope_text ?? "Careful diagnostics, practical repairs, and seasonal maintenance.";
const heroScopeHtml = heroScopeText.replace(
	/\b(diagnostics|repairs|maintenance|service|winterization|startups)\b/gi,
	"<span>$1</span>",
);
const heroImage = home.data.hero_image ?? "/uploads/hero-construction.jpg";
const imageMimeTypes: Record<string, string> = {
	".jpg": "image/jpeg",
	".jpeg": "image/jpeg",
	".png": "image/png",
	".webp": "image/webp",
};
const heroImagePath = heroImage.startsWith("/") ? `public${heroImage}` : undefined;
const heroImageMimeType = imageMimeTypes[extname(heroImage).toLowerCase()];
const heroImageSrc =
	heroImagePath && heroImageMimeType
		? `data:${heroImageMimeType};base64,${readFileSync(heroImagePath).toString("base64")}`
		: heroImage;
const logoSvg = readFileSync("public/uploads/luc-logo-simplified-transparent.svg", "utf8");
const footer = home.data.footer ?? {};
const footerServiceArea = footer.service_area ?? home.data.service_area;
const footerHighlights = footer.highlights?.length ? footer.highlights : ["Free Estimates", "Residential Services"];
const footerLegal = footer.legal ?? "All rights reserved.";
---

<Layout
	title={meta.title}
	description={meta.description}
	canonicalPath={meta.canonicalPath}
	socialTitle={meta.socialTitle}
	socialDescription={meta.socialDescription}
	socialImage={meta.socialImage}
>
	<style is:inline slot="head">
		html {
			background: #070807;
			scroll-behavior: smooth;
			scrollbar-gutter: stable;
			scroll-padding-top: 96px;
		}

		body {
			background: #070807;
			color: #f4efe4;
			font-family:
				Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
				sans-serif;
			margin: 0;
			overflow-x: hidden;
		}

		* {
			box-sizing: border-box;
		}

		.site-header {
			align-items: center;
			display: flex;
			justify-content: space-between;
			left: 50%;
			margin: 0;
			max-width: 1120px;
			min-height: 64px;
			padding: 4px 14px;
			position: fixed;
			top: 16px;
			transform: translateX(-50%);
			width: calc(100% - 48px);
			z-index: 10;
		}

		.brand {
			align-items: center;
			display: inline-flex;
			gap: 12px;
			text-decoration: none;
		}

		.brand-mark {
			align-items: center;
			display: inline-flex;
			height: 84px;
			justify-content: center;
			width: 124px;
		}

		.brand-mark svg {
			display: block;
			height: 100%;
			width: 100%;
		}

		.nav-toggle {
			display: none;
		}

		nav {
			display: flex;
			gap: 8px;
		}

		nav a {
			padding: 10px 14px;
			text-decoration: none;
		}

		main {
			padding-top: 88px;
		}

		.hero {
			display: grid;
			gap: clamp(22px, 3.2vw, 36px);
			grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
			margin: 0 auto;
			max-width: 1120px;
			min-height: 0;
			padding: 28px 24px clamp(24px, 4vh, 42px);
		}

		.hero-copy {
			align-self: center;
		}

		h1 {
			color: #ffffff;
			font-size: clamp(2.9rem, 6.2vw, 5.25rem);
			letter-spacing: 0;
			line-height: 0.95;
			margin: 0 0 24px;
			max-width: 880px;
		}

		.lede,
		.hero-lede {
			color: #b8b2a4;
			font-size: 1.05rem;
			line-height: 1.7;
			margin: 0 clamp(16px, 3vw, 44px) 0 0;
			max-width: 640px;
		}

		.actions {
			align-items: center;
			display: flex;
			flex-wrap: wrap;
			gap: 18px;
			margin-top: 34px;
		}

		.button {
			display: inline-flex;
			justify-content: center;
			min-width: 180px;
			padding: 15px 22px;
		}

		.hero-panel {
			aspect-ratio: 0.86;
			background:
				linear-gradient(180deg, rgba(217, 178, 86, 0.08), rgba(7, 8, 7, 0.18)),
				#101211;
			background-color: #101211;
			border: 1px solid rgba(217, 178, 86, 0.28);
			border-radius: 8px;
			box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
			display: grid;
			height: clamp(500px, 66svh, 660px);
			justify-self: end;
			min-height: 0;
			padding: 18px;
			position: relative;
			z-index: 1;
			width: min(100%, 540px);
		}

		.hero-image {
			border-radius: inherit;
			height: 100%;
			inset: 0;
			object-fit: cover;
			object-position: center;
			opacity: 1;
			position: absolute;
			transition: none;
			width: 100%;
			z-index: 0;
		}

		.hero-scrim {
			background: linear-gradient(180deg, rgba(7, 8, 7, 0.05), rgba(7, 8, 7, 0.28));
			border-radius: inherit;
			inset: 0;
			pointer-events: none;
			position: absolute;
			z-index: 1;
		}

		.hero-panel::before {
			border: 1px solid rgba(240, 213, 139, 0.78);
			border-radius: 6px;
			content: "";
			inset: 16px;
			pointer-events: none;
			position: absolute;
			z-index: 2;
		}

		.hero-frame {
			align-self: end;
			background: rgba(7, 8, 7, 0.88);
			border: 1px solid rgba(240, 213, 139, 0.36);
			border-radius: 8px;
			justify-self: center;
			max-width: min(100%, 340px);
			padding: 22px 24px 20px;
			position: relative;
			text-align: center;
			z-index: 3;
		}

		.scope-label {
			color: #f0d58b;
			display: block;
			font-size: 0.72rem;
			font-weight: 800;
			letter-spacing: 0.18em;
			margin-bottom: 12px;
			text-transform: uppercase;
		}

		.scope-list {
			color: rgba(244, 239, 228, 0.82);
			display: block;
			font-size: 1rem;
			line-height: 1.55;
		}

		.scope-list span {
			color: #d9b256;
			font-weight: 800;
		}

		@media (max-width: 820px) {
			html {
				scroll-padding-top: 82px;
			}

			.site-header {
				align-items: center;
				flex-direction: row;
				min-height: 58px;
				padding: 3px 12px;
				top: 12px;
				width: calc(100% - 44px);
			}

			.brand {
				font-size: 0.86rem;
				gap: 10px;
				min-width: 0;
			}

			.brand-mark {
				height: 64px;
				width: 100px;
			}

			.brand span:last-child {
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.nav-toggle {
				display: inline-flex;
			}

			nav {
				flex-direction: column;
				left: 0;
				opacity: 0;
				pointer-events: none;
				position: absolute;
				right: 0;
				top: calc(100% + 8px);
				transform: translateY(-6px);
				width: 100%;
			}

			main {
				padding-top: 76px;
			}

			h1 {
				font-size: clamp(2.35rem, 10vw, 3.6rem);
				line-height: 1.1;
				margin-bottom: 16px;
			}

			.hero .eyebrow {
				display: none;
			}

			.hero h1 {
				padding-top: 14px;
			}

			.hero-lede {
				font-size: 1rem;
				line-height: 1.55;
				margin: 0 auto;
				max-width: min(100% - 32px, 560px);
				text-align: left;
			}

			.actions {
				align-items: center;
				gap: 12px;
				justify-content: center;
				margin-top: 22px;
				text-align: center;
				width: 100%;
			}

			.hero {
				gap: 18px;
				grid-template-columns: 1fr;
				min-height: auto;
				padding: 0;
			}

			.hero-copy {
				justify-self: center;
				padding-top: 22px;
				text-align: center;
				width: min(100%, 680px);
			}

			.hero-panel {
				aspect-ratio: 0.92;
				height: clamp(300px, 44svh, 380px);
				min-height: 0;
				justify-self: center;
				margin-top: 18px;
				width: min(88vw, 360px);
			}

			.hero-panel::after {
				background: linear-gradient(90deg, transparent, rgba(240, 213, 139, 0.52), transparent);
				content: "";
				height: 1px;
				left: 50%;
				position: absolute;
				top: -18px;
				transform: translateX(-50%);
				width: min(76vw, 320px);
			}

			.hero-frame {
				padding: 26px 20px 22px;
			}
		}
	</style>
	<header class="site-header">
		<a class="brand" href="/" aria-label="Luc Contracting home">
			<span class="brand-mark" aria-hidden="true" set:html={logoSvg}></span>
			<span>Luc Contracting</span>
		</a>
		<button class="nav-toggle" type="button" aria-controls="primary-nav" aria-expanded="false" aria-label="Open navigation">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<nav id="primary-nav" aria-label="Primary navigation">
			<a href="#services">Services</a>
			<a href="#work">Work</a>
			<a href="#contact">Contact</a>
		</nav>
	</header>

	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">{home.data.hero_eyebrow ?? "Irrigation contracting"}</p>
				<h1>{home.data.hero_heading}</h1>
				<p class="lede hero-lede">{home.data.hero_text}</p>
				<div class="actions">
					<a class="button" href="#contact">
						{home.data.cta_label ?? "Request an estimate"}
					</a>
					<a class="text-link" href="#services">View services</a>
				</div>
			</div>
			<div class="hero-panel" aria-label="Project highlights">
				<img class="hero-image" src={heroImageSrc} alt="" width="1600" height="1067" loading="eager" decoding="sync" fetchpriority="high" />
				<span class="hero-scrim" aria-hidden="true"></span>
				<div class="hero-frame">
					<span class="scope-label">{home.data.hero_scope_label ?? "What We Handle:"}</span>
					<div class="scope-list" aria-label="Luc Contracting capabilities" set:html={heroScopeHtml} />
				</div>
			</div>
		</section>

		<section class="intro" aria-label="About Luc Contracting">
			<div>
				<h2>{home.data.intro_heading ?? "Clear work, steady communication, clean results."}</h2>
			</div>
			<div class="rich-text">
				<Content />
				{home.data.service_area && <p>{home.data.service_area}</p>}
			</div>
		</section>

		<section id="services" class="section">
			<div class="section-heading">
				<p class="eyebrow">{home.data.services_eyebrow ?? "Services"}</p>
				<h2>{home.data.services_heading ?? "Built for practical residential and small commercial projects."}</h2>
			</div>
			<div class="service-grid">
				{services.map((service) => (
					<article>
						<h3>{service.data.title}</h3>
						<p>{service.data.summary}</p>
					</article>
				))}
			</div>
		</section>

		<section id="work" class="section work">
			<div class="section-heading">
				<p class="eyebrow">{home.data.projects_eyebrow ?? "Recent work"}</p>
				<h2>{home.data.projects_heading ?? "Simple examples Decap can update as new projects finish."}</h2>
			</div>
			<div class="project-list">
				{projects.map((project) => (
					<article class={project.data.image ? "has-image" : undefined}>
						{project.data.image && (
							<img src={project.data.image} alt="" width="1600" height="1060" loading="lazy" decoding="async" />
						)}
						<div class="project-copy">
							<div>
								<h3>{project.data.title}</h3>
								{project.data.location && <p class="meta">{project.data.location}</p>}
							</div>
							<p>{project.data.summary}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="contact" class="contact">
			<div>
				<p class="eyebrow">{home.data.contact?.eyebrow ?? "Start a project"}</p>
				<h2>{home.data.contact?.heading ?? "Tell us what you need built, repaired, or managed."}</h2>
			</div>
			<div class="contact-actions">
				<a class="button" href={`tel:${contactPhone.replace(/[^\d+]/g, "")}`}>
					{contactPhone}
				</a>
				{contactEmail && <a class="text-link" href={`mailto:${contactEmail}`}>{contactEmail}</a>}
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="footer-panel">
			{footerServiceArea && (
				<div class="footer-details">
					<span>{footerServiceArea}</span>
				</div>
			)}
			{footerHighlights.length > 0 && (
				<div class="footer-details footer-legal">
					{footerHighlights.map((highlight) => <span>{highlight}</span>)}
				</div>
			)}
			<div class="footer-bottomline">
				<span>&copy; {new Date().getFullYear()} Luc Contracting. {footerLegal}</span>
			</div>
		</div>
	</footer>

	<script is:inline>
		const header = document.querySelector(".site-header");
		const toggle = document.querySelector(".nav-toggle");
		const nav = document.querySelector("#primary-nav");

		if (header && toggle && nav) {
			const mobileQuery = window.matchMedia("(max-width: 820px)");
			let lastScrollY = window.scrollY;
			let scrollTicking = false;

			const setMenuState = (isOpen) => {
				header.classList.toggle("nav-open", isOpen);
				header.classList.remove("header-hidden");
				toggle.setAttribute("aria-expanded", String(isOpen));
				toggle.setAttribute("aria-label", isOpen ? "Close navigation" : "Open navigation");
			};

			const syncHeaderVisibility = () => {
				if (!mobileQuery.matches) {
					header.classList.remove("header-hidden");
					lastScrollY = window.scrollY;
					return;
				}

				const currentScrollY = Math.max(window.scrollY, 0);
				const isMenuOpen = header.classList.contains("nav-open");
				const scrolledDown = currentScrollY > lastScrollY + 8;
				const scrolledUp = currentScrollY < lastScrollY - 8;

				if (isMenuOpen || currentScrollY < 72 || scrolledUp) {
					header.classList.remove("header-hidden");
				} else if (scrolledDown) {
					header.classList.add("header-hidden");
				}

				if (Math.abs(currentScrollY - lastScrollY) > 8) {
					lastScrollY = currentScrollY;
				}
			};

			toggle.addEventListener("click", () => {
				setMenuState(!header.classList.contains("nav-open"));
			});

			nav.addEventListener("click", (event) => {
				if (event.target instanceof HTMLAnchorElement) {
					setMenuState(false);
				}
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape") {
					setMenuState(false);
				}
			});

			window.addEventListener(
				"scroll",
				() => {
					if (!scrollTicking) {
						window.requestAnimationFrame(() => {
							syncHeaderVisibility();
							scrollTicking = false;
						});
						scrollTicking = true;
					}
				},
				{ passive: true },
			);

			mobileQuery.addEventListener("change", () => {
				header.classList.remove("header-hidden");
				lastScrollY = window.scrollY;
			});
		}
	</script>
</Layout>

<style>
	:root {
		--black: #070807;
		--charcoal: #101211;
		--ink: #181b19;
		--gold: #d9b256;
		--gold-soft: #f0d58b;
		--line: rgba(217, 178, 86, 0.28);
		--cream: #f4efe4;
		--muted: #b8b2a4;
	}

	.site-header {
		align-items: center;
		backdrop-filter: blur(18px);
		background: linear-gradient(90deg, rgba(7, 8, 7, 0.86), rgba(17, 19, 18, 0.78));
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
		display: flex;
		justify-content: space-between;
		left: 50%;
		margin: 0;
		max-width: 1120px;
		min-height: 64px;
		padding: 4px 14px;
		position: fixed;
		top: 16px;
		transform: translateX(-50%);
		width: calc(100% - 48px);
		z-index: 10;
	}

	.brand {
		align-items: center;
		color: #ffffff;
		display: inline-flex;
		gap: 12px;
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.brand-mark {
		align-items: center;
		display: inline-flex;
		height: 84px;
		justify-content: center;
		width: 124px;
	}

	.brand-mark svg {
		display: block;
		height: 100%;
		width: 100%;
	}

	.nav-toggle {
		display: none;
	}

	nav {
		display: flex;
		gap: 8px;
	}

	nav a,
	.text-link {
		font-weight: 700;
		text-decoration: none;
	}

	nav a {
		border-radius: 999px;
		color: #f5f1e8;
		padding: 10px 14px;
	}

	nav a:hover {
		background: rgba(217, 178, 86, 0.12);
		color: var(--gold-soft);
	}

	main {
		background:
			linear-gradient(
				180deg,
				transparent 0,
				transparent 540px,
				rgba(16, 18, 17, 0.52) 850px,
				rgba(16, 18, 17, 0.28) 1240px,
				transparent 1580px
			),
			linear-gradient(
				180deg,
				transparent 0,
				transparent 58%,
				rgba(217, 178, 86, 0.045) 68%,
				rgba(7, 8, 7, 0) 82%
			);
		overflow: hidden;
		padding-top: 88px;
		position: relative;
	}

	main::before {
		background:
			radial-gradient(circle, rgba(217, 178, 86, 0.42) 2.4px, transparent 2.9px) 0 0 / 34px 34px,
			linear-gradient(135deg, rgba(217, 178, 86, 0.1), transparent 64%);
		content: "";
		height: 620px;
		left: max(38vw, calc((100vw - 1120px) / 2 + 430px));
		mask-image: radial-gradient(ellipse at 52% 48%, #000 0 48%, transparent 76%);
		opacity: 0.62;
		pointer-events: none;
		position: absolute;
		top: 154px;
		width: 720px;
	}

	.hero,
	.intro,
	.section,
	.contact {
		margin: 0 auto;
		max-width: 1120px;
		padding: 56px 24px;
		position: relative;
		z-index: 1;
	}

		.hero {
			align-items: stretch;
			display: grid;
			gap: clamp(22px, 3.2vw, 36px);
			grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
			min-height: 0;
			padding-bottom: clamp(24px, 4vh, 42px);
			padding-top: 74px;
			position: relative;
		}

	.hero-copy {
		align-self: center;
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		color: var(--gold);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		color: #ffffff;
		font-size: clamp(2.9rem, 6.2vw, 5.25rem);
		letter-spacing: 0;
		line-height: 1.1;
		margin-bottom: 24px;
		max-width: 880px;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1;
		margin-bottom: 0;
	}

	h3 {
		color: #ffffff;
		font-size: 1.25rem;
		margin-bottom: 12px;
	}

	.lede,
	.rich-text,
	.service-grid p,
	.project-list p {
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.lede,
	.hero-lede {
		margin: 0 clamp(16px, 3vw, 44px) 0 0;
		max-width: 640px;
	}

	.actions,
	.contact-actions {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
		margin-top: 34px;
	}

	.button {
		background: linear-gradient(135deg, var(--gold-soft), var(--gold));
		border-radius: 6px;
		box-shadow: 0 14px 30px rgba(217, 178, 86, 0.22);
		color: var(--black);
		display: inline-flex;
		font-weight: 800;
		justify-content: center;
		min-width: 180px;
		padding: 15px 22px;
		text-decoration: none;
