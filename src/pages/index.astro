---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const home = await getEntry("pages", "home");
const siteMetadata = await getEntry("site", "metadata");
const services = (await getCollection("services")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const projects = (await getCollection("projects")).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

if (!home) {
	throw new Error("Missing src/content/pages/home.md");
}

const { Content } = await render(home);
const contactPhone = home.data.contact?.phone || home.data.phone;
const contactEmail = home.data.contact?.email || home.data.email;
const metadata = siteMetadata?.data ?? home.data.meta;
const meta = {
	title: metadata?.title ?? home.data.title ?? "Luc Contracting",
	description: metadata?.description ?? home.data.description,
	canonicalPath: metadata?.canonical_path ?? "/",
	socialTitle: metadata?.social_title,
	socialDescription: metadata?.social_description,
	socialImage: metadata?.social_image,
};
const heroScopeText = home.data.hero_scope_text ?? "Careful diagnostics, practical repairs, and seasonal maintenance.";
const heroScopeHtml = heroScopeText.replace(
	/\b(diagnostics|repairs|maintenance|service|winterization|startups)\b/gi,
	"<span>$1</span>",
);
const heroImage = home.data.hero_image ?? "/uploads/hero-construction.jpg";
const footer = home.data.footer ?? {};
const footerServiceArea = footer.service_area ?? home.data.service_area;
const footerHighlights = footer.highlights?.length ? footer.highlights : ["Free Estimates", "Residential Services"];
const footerLegal = footer.legal ?? "All rights reserved.";
---

<Layout
	title={meta.title}
	description={meta.description}
	canonicalPath={meta.canonicalPath}
	socialTitle={meta.socialTitle}
	socialDescription={meta.socialDescription}
	socialImage={meta.socialImage}
>
	<style is:inline slot="head">
		html {
			background: #070807;
			scroll-behavior: smooth;
			scrollbar-gutter: stable;
			scroll-padding-top: 120px;
		}

		body {
			background: #070807;
			color: #f4efe4;
			margin: 0;
			overflow-x: hidden;
		}

		.site-header {
			align-items: center;
			display: flex;
			justify-content: space-between;
			left: 50%;
			margin: 0;
			max-width: 1120px;
			min-height: 72px;
			padding: 14px 18px;
			position: fixed;
			top: 16px;
			transform: translateX(-50%);
			width: calc(100% - 48px);
			z-index: 10;
		}

		main {
			padding-top: 112px;
		}

		.hero {
			display: grid;
			gap: 36px;
			grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
			margin: 0 auto;
			max-width: 1120px;
			min-height: 680px;
			padding: 82px 24px 90px;
		}

		.hero-copy {
			align-self: center;
		}

		.hero-panel {
			aspect-ratio: 0.86;
			min-height: 420px;
		}

		.hero-frame {
			align-self: end;
			background: rgba(7, 8, 7, 0.88);
			border: 1px solid rgba(240, 213, 139, 0.36);
			border-radius: 8px;
			justify-self: center;
			max-width: min(100%, 340px);
			padding: 22px 24px 20px;
			position: relative;
			text-align: center;
			z-index: 1;
		}

		.scope-label {
			color: #f0d58b;
			display: block;
			font-size: 0.72rem;
			font-weight: 800;
			letter-spacing: 0.18em;
			margin-bottom: 12px;
			text-transform: uppercase;
		}

		.scope-list {
			color: rgba(244, 239, 228, 0.82);
			display: block;
			font-size: 1rem;
			line-height: 1.55;
		}

		.scope-list span {
			color: #d9b256;
			font-weight: 800;
		}

		@media (max-width: 820px) {
			html {
				scroll-padding-top: 252px;
			}

			.site-header,
			nav {
				align-items: flex-start;
				flex-direction: column;
			}

			.site-header {
				gap: 14px;
				top: 12px;
				width: calc(100% - 44px);
			}

			nav {
				gap: 6px;
				width: 100%;
			}

			main {
				padding-top: 272px;
			}

			.hero {
				grid-template-columns: 1fr;
				min-height: auto;
				padding-top: 28px;
			}

			.hero-panel {
				aspect-ratio: 4 / 3;
				min-height: 320px;
			}
		}
	</style>
	<link slot="head" rel="preload" as="image" href={heroImage} fetchpriority="high" />

	<header class="site-header">
		<a class="brand" href="/" aria-label="Luc Contracting home">
			<span class="brand-mark">LC</span>
			<span>Luc Contracting</span>
		</a>
		<nav aria-label="Primary navigation">
			<a href="#services">Services</a>
			<a href="#work">Work</a>
			<a href="#contact">Contact</a>
		</nav>
	</header>

	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">{home.data.hero_eyebrow ?? "Irrigation contracting"}</p>
				<h1>{home.data.hero_heading}</h1>
				<p class="lede">{home.data.hero_text}</p>
				<div class="actions">
					<a class="button" href={`tel:${home.data.phone.replace(/[^\d+]/g, "")}`}>
						{home.data.cta_label ?? "Request an estimate"}
					</a>
					<a class="text-link" href="#services">View services</a>
				</div>
			</div>
			<div class="hero-panel" aria-label="Project highlights" style={`--hero-image: url("${heroImage}")`}>
				<div class="hero-frame">
					<span class="scope-label">{home.data.hero_scope_label ?? "What We Handle:"}</span>
					<div class="scope-list" aria-label="Luc Contracting capabilities" set:html={heroScopeHtml} />
				</div>
			</div>
		</section>

		<section class="intro" aria-label="About Luc Contracting">
			<div>
				<h2>{home.data.intro_heading ?? "Clear work, steady communication, clean results."}</h2>
			</div>
			<div class="rich-text">
				<Content />
				{home.data.service_area && <p>{home.data.service_area}</p>}
			</div>
		</section>

		<section id="services" class="section">
			<div class="section-heading">
				<p class="eyebrow">{home.data.services_eyebrow ?? "Services"}</p>
				<h2>{home.data.services_heading ?? "Built for practical residential and small commercial projects."}</h2>
			</div>
			<div class="service-grid">
				{services.map((service) => (
					<article>
						<h3>{service.data.title}</h3>
						<p>{service.data.summary}</p>
					</article>
				))}
			</div>
		</section>

		<section id="work" class="section work">
			<div class="section-heading">
				<p class="eyebrow">{home.data.projects_eyebrow ?? "Recent work"}</p>
				<h2>{home.data.projects_heading ?? "Simple examples Decap can update as new projects finish."}</h2>
			</div>
			<div class="project-list">
				{projects.map((project) => (
					<article class={project.data.image ? "has-image" : undefined}>
						{project.data.image && (
							<img src={project.data.image} alt="" loading="lazy" decoding="async" />
						)}
						<div class="project-copy">
							<div>
								<h3>{project.data.title}</h3>
								{project.data.location && <p class="meta">{project.data.location}</p>}
							</div>
							<p>{project.data.summary}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="contact" class="contact">
			<div>
				<p class="eyebrow">{home.data.contact?.eyebrow ?? "Start a project"}</p>
				<h2>{home.data.contact?.heading ?? "Tell us what you need built, repaired, or managed."}</h2>
			</div>
			<div class="contact-actions">
				<a class="button" href={`tel:${contactPhone.replace(/[^\d+]/g, "")}`}>
					{contactPhone}
				</a>
				{contactEmail && <a class="text-link" href={`mailto:${contactEmail}`}>{contactEmail}</a>}
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="footer-panel">
			{footerServiceArea && (
				<div class="footer-details">
					<span>{footerServiceArea}</span>
				</div>
			)}
			{footerHighlights.length > 0 && (
				<div class="footer-details footer-legal">
					{footerHighlights.map((highlight) => <span>{highlight}</span>)}
				</div>
			)}
			<div class="footer-bottomline">
				<span>&copy; {new Date().getFullYear()} Luc Contracting. {footerLegal}</span>
			</div>
		</div>
	</footer>
</Layout>

<style>
	:root {
		--black: #070807;
		--charcoal: #101211;
		--ink: #181b19;
		--gold: #d9b256;
		--gold-soft: #f0d58b;
		--line: rgba(217, 178, 86, 0.28);
		--cream: #f4efe4;
		--muted: #b8b2a4;
	}

	.site-header {
		align-items: center;
		backdrop-filter: blur(18px);
		background: linear-gradient(90deg, rgba(7, 8, 7, 0.86), rgba(17, 19, 18, 0.78));
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
		display: flex;
		justify-content: space-between;
		left: 50%;
		margin: 0;
		max-width: 1120px;
		min-height: 72px;
		padding: 14px 18px;
		position: fixed;
		top: 16px;
		transform: translateX(-50%);
		width: calc(100% - 48px);
		z-index: 10;
	}

	.brand {
		align-items: center;
		color: #ffffff;
		display: inline-flex;
		gap: 12px;
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.brand-mark {
		align-items: center;
		background: linear-gradient(135deg, var(--gold-soft), var(--gold));
		border-radius: 50%;
		color: var(--black);
		display: inline-flex;
		font-size: 0.78rem;
		height: 42px;
		justify-content: center;
		width: 42px;
	}

	nav {
		display: flex;
		gap: 8px;
	}

	nav a,
	.text-link {
		font-weight: 700;
		text-decoration: none;
	}

	nav a {
		border-radius: 999px;
		color: #f5f1e8;
		padding: 10px 14px;
	}

	nav a:hover {
		background: rgba(217, 178, 86, 0.12);
		color: var(--gold-soft);
	}

	main {
		background:
			linear-gradient(
				180deg,
				transparent 0,
				transparent 540px,
				rgba(16, 18, 17, 0.52) 850px,
				rgba(16, 18, 17, 0.28) 1240px,
				transparent 1580px
			),
			linear-gradient(
				180deg,
				transparent 0,
				transparent 58%,
				rgba(217, 178, 86, 0.045) 68%,
				rgba(7, 8, 7, 0) 82%
			);
		overflow: hidden;
		padding-top: 112px;
		position: relative;
	}

	main::before {
		background:
			radial-gradient(circle, rgba(217, 178, 86, 0.42) 2.4px, transparent 2.9px) 0 0 / 34px 34px,
			linear-gradient(135deg, rgba(217, 178, 86, 0.1), transparent 64%);
		content: "";
		height: 620px;
		left: max(38vw, calc((100vw - 1120px) / 2 + 430px));
		mask-image: radial-gradient(ellipse at 52% 48%, #000 0 48%, transparent 76%);
		opacity: 0.62;
		pointer-events: none;
		position: absolute;
		top: 154px;
		width: 720px;
	}

	.hero,
	.intro,
	.section,
	.contact {
		margin: 0 auto;
		max-width: 1120px;
		padding: 72px 24px;
		position: relative;
		z-index: 1;
	}

	.hero {
		align-items: stretch;
		display: grid;
		gap: 36px;
		grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
		min-height: 680px;
		padding-bottom: 90px;
		padding-top: 82px;
		position: relative;
	}

	.hero-copy {
		align-self: center;
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		color: var(--gold);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		color: #ffffff;
		font-size: clamp(3rem, 7vw, 5.85rem);
		letter-spacing: 0;
		line-height: 0.95;
		margin-bottom: 24px;
		max-width: 880px;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1;
		margin-bottom: 0;
	}

	h3 {
		color: #ffffff;
		font-size: 1.25rem;
		margin-bottom: 12px;
	}

	.lede,
	.rich-text,
	.service-grid p,
	.project-list p {
		color: var(--muted);
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.lede {
		max-width: 640px;
	}

	.actions,
	.contact-actions {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
		margin-top: 34px;
	}

	.button {
		background: linear-gradient(135deg, var(--gold-soft), var(--gold));
		border-radius: 6px;
		box-shadow: 0 14px 30px rgba(217, 178, 86, 0.22);
		color: var(--black);
		display: inline-flex;
		font-weight: 800;
		justify-content: center;
		min-width: 180px;
		padding: 15px 22px;
		text-decoration: none;
	}

	.hero-panel {
		aspect-ratio: 0.86;
		background:
			linear-gradient(180deg, rgba(7, 8, 7, 0.05), rgba(7, 8, 7, 0.28)),
			var(--hero-image);
		background-position: center;
		background-size: cover;
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
		display: grid;
		min-height: 420px;
		padding: 18px;
		position: relative;
		z-index: 1;
	}

	.hero-panel::before {
		border: 1px solid rgba(240, 213, 139, 0.78);
		border-radius: 6px;
		content: "";
		inset: 16px;
		pointer-events: none;
		position: absolute;
	}

	.hero-frame {
		align-self: end;
		backdrop-filter: blur(14px);
		background:
			linear-gradient(135deg, rgba(7, 8, 7, 0.9), rgba(16, 18, 17, 0.74)),
			linear-gradient(135deg, rgba(240, 213, 139, 0.16), transparent 56%);
		border: 1px solid rgba(240, 213, 139, 0.36);
		border-radius: 8px;
		box-shadow: 0 18px 45px rgba(0, 0, 0, 0.32);
		justify-self: center;
		max-width: min(100%, 360px);
		padding: 24px 26px 22px;
		position: relative;
		text-align: center;
		z-index: 1;
	}

	.hero-frame::before {
		background: linear-gradient(90deg, transparent, var(--gold-soft), var(--gold), transparent);
		content: "";
		height: 2px;
		left: 50%;
		position: absolute;
		top: 14px;
		transform: translateX(-50%);
		width: 86px;
	}

	.scope-label {
		color: var(--gold-soft);
		display: block;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		margin-bottom: 10px;
		text-transform: uppercase;
	}

	.scope-list {
		color: rgba(244, 239, 228, 0.82);
		display: block;
		font-size: 1rem;
		line-height: 1.5;
	}

	.scope-list span {
		color: var(--gold-soft);
		font-weight: 700;
	}

	.intro {
		content-visibility: auto;
		contain-intrinsic-size: auto 280px;
		display: grid;
		gap: 48px;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		padding-top: 86px;
	}

	.section,
	.contact {
		content-visibility: auto;
		contain-intrinsic-size: auto 420px;
	}

	.section-heading {
		margin-bottom: 34px;
		max-width: 760px;
	}

	.service-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-grid article,
	.project-list article {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025));
		border: 1px solid var(--line);
		border-radius: 8px;
		padding: 24px;
	}

	.service-grid article {
		background: linear-gradient(
			145deg,
			rgba(240, 213, 139, 0.18) 0,
			rgba(217, 178, 86, 0.09) 28%,
			rgba(255, 255, 255, 0.045) 58%,
			rgba(7, 8, 7, 0.34) 100%
		);
		border-color: rgba(240, 213, 139, 0.34);
	}

	.project-list article {
		background: linear-gradient(
			145deg,
			rgba(240, 213, 139, 0.1) 0,
			rgba(217, 178, 86, 0.045) 20%,
			rgba(255, 255, 255, 0.04) 48%,
			rgba(7, 8, 7, 0.4) 100%
		);
		border-color: rgba(240, 213, 139, 0.24);
	}

	.work {
		max-width: none;
		padding-bottom: 138px;
		padding-left: max(24px, calc((100vw - 1120px) / 2 + 24px));
		padding-right: max(24px, calc((100vw - 1120px) / 2 + 24px));
		padding-top: 138px;
		position: relative;
	}

	.work::before {
		background: linear-gradient(180deg, rgba(7, 8, 7, 0), rgba(217, 178, 86, 0.055), rgba(7, 8, 7, 0));
		content: "";
		inset: 18px auto 18px 50%;
		opacity: 1;
		pointer-events: none;
		position: absolute;
		transform: translateX(-50%);
		width: 100vw;
		z-index: 0;
	}

	.work > * {
		position: relative;
		z-index: 1;
	}

	.project-list {
		display: grid;
		gap: 16px;
	}

	.project-list article {
		align-items: start;
		display: grid;
		gap: 24px;
		grid-template-columns: 0.45fr 1fr;
	}

	.project-list article.has-image {
		align-items: center;
		grid-template-columns: 220px minmax(0, 1fr);
		padding: 18px;
	}

	.project-list img {
		aspect-ratio: 4 / 3;
		border: 1px solid rgba(240, 213, 139, 0.22);
		border-radius: 6px;
		height: 165px;
		object-fit: cover;
		width: 220px;
	}

	.project-copy {
		align-items: start;
		display: grid;
		gap: 24px;
		grid-template-columns: 0.45fr 1fr;
		padding: 10px;
	}

	.project-list article:not(.has-image) .project-copy {
		display: contents;
	}

	.project-list article.has-image .project-copy {
		display: block;
		padding: 0;
	}

	.project-list article.has-image .project-copy p:last-child {
		margin-bottom: 0;
	}

	.meta {
		color: var(--gold);
		font-weight: 800;
		margin-bottom: 0;
	}

	.contact {
		align-items: center;
		display: grid;
		gap: 32px;
		grid-template-columns: minmax(0, 1fr) auto;
	}

	.site-footer {
		margin: 0 auto;
		max-width: 1120px;
		padding: 18px 24px 34px;
	}

	.footer-panel {
		background:
			linear-gradient(145deg, rgba(240, 213, 139, 0.08), rgba(255, 255, 255, 0.025) 42%, rgba(7, 8, 7, 0.24)),
			rgba(255, 255, 255, 0.025);
		border: 1px solid rgba(217, 178, 86, 0.18);
		border-radius: 8px;
		color: rgba(244, 239, 228, 0.58);
		font-size: 0.78rem;
		padding: 18px;
	}

	.footer-details,
	.footer-bottomline {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 0;
	}

	.footer-details {
		margin-bottom: 12px;
	}

	.footer-legal {
		color: rgba(244, 239, 228, 0.42);
	}

	.footer-bottomline {
		border-top: 1px solid rgba(217, 178, 86, 0.1);
		justify-content: space-between;
		margin-top: 16px;
		padding-top: 16px;
	}

	.site-footer a,
	.site-footer span {
		line-height: 1.5;
		margin: 0;
	}

	.site-footer a {
		color: var(--gold-soft);
		font-weight: 700;
		text-decoration: none;
	}

	.footer-details a,
	.footer-details span {
		padding: 0;
	}

	.footer-details span + span::before {
		color: rgba(217, 178, 86, 0.48);
		content: "/";
		margin: 0 10px;
	}

	.footer-bottomline a {
		color: #070807;
		background: linear-gradient(135deg, var(--gold-soft), var(--gold));
		border-radius: 999px;
		padding: 8px 12px;
	}

	.text-link {
		color: var(--gold-soft);
	}

	@media (max-width: 820px) {
		.site-header,
		nav,
		.actions,
		.contact-actions {
			align-items: flex-start;
			flex-direction: column;
		}

		.site-header {
			gap: 14px;
			top: 12px;
			width: calc(100% - 44px);
		}

		nav {
			gap: 6px;
			width: 100%;
		}

		main {
			padding-top: 272px;
		}

		.hero,
		.intro,
		.contact,
		.project-list article,
		.project-copy {
